# FastPanel panel URL including port. No trailing slash.
FASTPANEL_URL=https://panel.example.com:8888

# Read token — required. Create with:
#   fastpanel users tokens add -n mcp-read -s read_only -e YYYY-MM-DD
FASTPANEL_TOKEN=

# Write token — optional. Write tools (user_create, site_create, etc.) refuse to
# run without it. Recommended: keep it unset during normal use, only set when
# you actually need to mutate state. Create with:
#   fastpanel users tokens add -n mcp-write -c <your-ip> -e YYYY-MM-DD
FASTPANEL_WRITE_TOKEN=

# Set to "1" to skip TLS verification (FastPanel panels often use self-signed certs).
FASTPANEL_INSECURE_TLS=1

# Request timeout in ms. Optional.
FASTPANEL_TIMEOUT_MS=30000

# ── Optional SSH layer ────────────────────────────────────────────────────────
# Enables host-level tools (nginx_validate, site_doctor) that the REST API can't
# do. Opt-in: everything stays REST-only until FASTPANEL_SSH_HOST is set. Uses your
# machine's own `ssh` client, so the host must already be reachable with key auth
# (BatchMode). Nothing here is server-specific — point it at any FastPanel host.
# FASTPANEL_SSH_HOST=panel.example.com
# FASTPANEL_SSH_USER=root            # default: root
# FASTPANEL_SSH_PORT=22              # default: 22
# FASTPANEL_SSH_KEY=/path/to/id_ed25519   # optional; omit to use ssh-agent/~/.ssh/config
# FASTPANEL_SSH_OPTS=                # optional extra -o options, comma-separated
# FASTPANEL_SSH_TIMEOUT_MS=15000     # default: 15000
# FASTPANEL_DUMP_DIR=/root/fastpanel-mcp-dumps   # staging dir for database_dump/import
#                                                # (set this if FASTPANEL_SSH_USER isn't root)

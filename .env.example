# FastPanel panel URL including port. No trailing slash.
FASTPANEL_URL=https://panel.example.com:8888

# Read token — required. Create with:
#   fastpanel users tokens add -n mcp-read -s read_only -e YYYY-MM-DD
FASTPANEL_TOKEN=

# Write token — optional. Write tools (user_create, site_create, etc.) refuse to
# run without it. Recommended: keep it unset during normal use, only set when
# you actually need to mutate state. Create with:
#   fastpanel users tokens add -n mcp-write -c <your-ip> -e YYYY-MM-DD
FASTPANEL_WRITE_TOKEN=

# Set to "1" to skip TLS verification (FastPanel panels often use self-signed certs).
FASTPANEL_INSECURE_TLS=1

# Request timeout in ms. Optional.
FASTPANEL_TIMEOUT_MS=30000
